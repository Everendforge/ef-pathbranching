{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Everend PathBranching",
  "version": "0.1.0",
  "identifier": "studio.everendforge.pathbranching",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 5174 --strictPort",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Everend PathBranching",
        "width": 1440,
        "height": 920,
        "minWidth": 1100,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
